    # Возвращает закрытые заявки, которые не обработаны Natasha:
    def get_closed_tickets_for_nlp(self):
        try:
            query = """
                SELECT 
                    t.id_tickets,
                    t.description,
                    t.labor_intensity,
                    t.id_executor,
                    t.priority
                FROM tickets t
                LEFT JOIN signs_tickets s ON t.id_tickets = s.id_ticket
                WHERE t.status = 'закрыта'
                  AND t.description IS NOT NULL
                  AND t.description != ''
                  AND t.labor_intensity IS NOT NULL
                  AND s.id_ticket IS NULL  -- НЕ обработаны
                ORDER BY t.id_tickets
            """
            self.cursor.execute(query)
            rows = self.cursor.fetchall()

            tickets = []
            for row in rows:
                tickets.append({
                    'id_tickets': row[0],
                    'description': row[1],
                    'labor_intensity': float(row[2]) if row[2] else None,
                    'id_executor': row[3],
                    'priority': row[4]
                })

            print(f"Найдено {len(tickets)} закрытых заявок для обработки Natasha")
            return tickets

        except psycopg2.Error as e:
            print(f"Ошибка: {e}")
            return []

    # Сохранение результатов обработки Natasha в таблицу signs_tickets:
    def save_nlp_results(self, ticket_id: int, result_nlp: dict, stats: dict, embedding: list):
