            self.cursor.execute(
                "SELECT id_signs_tickets FROM signs_tickets WHERE id_ticket = %s",
                (ticket_id,)
            )
            exists = self.cursor.fetchone()

            if exists:
                # Обновление:
                query = """
                    UPDATE signs_tickets SET
                        num_noun = %s, num_verb = %s, num_adj = %s,
                        num_per = %s, num_loc = %s, num_org = %s,
                        num_technology = %s, num_ner = %s, num_pos = %s,
                        noun_ratio = %s, verb_ratio = %s, adj_ratio = %s,
                        vector = %s
                    WHERE id_ticket = %s
                """
                self.cursor.execute(query, (
                    stats.get('Количество существительных', 0),
                    stats.get('Количество глаголов', 0),
                    stats.get('Количество прилагательных', 0),
                    stats.get('Количество PER', 0),
                    stats.get('Количество LOC', 0),
